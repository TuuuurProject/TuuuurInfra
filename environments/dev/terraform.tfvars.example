project_id = "my-gcp-project"
region     = "europe-west9"
env        = "dev"
app_name   = "webplat"

# Images container (Artifact Registry conseillé)
front_image = "europe-west9-docker.pkg.dev/my-gcp-project/apps/front:1.0.0"
api_image   = "europe-west9-docker.pkg.dev/my-gcp-project/apps/api:1.0.0"

# Domaines
front_domain = "app.example.com"
api_domain   = "api.example.com"

# DNS géré (optionnel)
create_dns_records = false
dns_zone_name      = null # ex: "example-com"

# Réseau (CIDRs à adapter si besoin)
app_subnet_cidr   = "10.10.0.0/24"
admin_subnet_cidr = "10.20.0.0/24"
connector_cidr    = "10.30.0.0/28"

# Redis
redis_memory_gb = 1
redis_tier      = "BASIC"
redis_auth      = false

# SQL Server
sql_mode = "cloudsql" # cloudsql | vm

# Cloud SQL for SQL Server
cloudsql_sqlserver_version = "SQLSERVER_2022_STANDARD"
cloudsql_tier              = "db-custom-1-3840"
cloudsql_disk_gb           = 50
cloudsql_disk_type         = "PD_SSD"
cloudsql_ha                = false

# Database
db_name            = "appdb"
db_user            = "appuser"
db_password        = "CHANGE_ME_STRONG_PASSWORD"      # ⚠️ Valeur dans le state Terraform
sql_root_password  = "CHANGE_ME_ROOT_STRONG_PASSWORD" # ⚠️ SQL Server root password

# SQL Server VM fallback (si sql_mode = "vm")
sql_vm_zone         = "europe-west9"
sql_vm_machine_type = "n2-standard-2"
sql_vm_boot_disk_gb = 50
sql_vm_image        = "windows-sql-cloud/sql-std-2019-win-2022"

# Cloud Run tuning
front_min_instances = 0
front_max_instances = 50
front_concurrency   = 80

api_min_instances = 0
api_max_instances = 50
api_concurrency   = 40

# Labels communs
labels = {
  owner = "platform-team"
}

# API Configuration
jwt_key            = "CHANGE_ME_JWT_SECRET_KEY_MIN_32_CHARS" # ⚠️ Minimum 32 caractères
google_client_id   = "your-google-client-id.apps.googleusercontent.com"

# SMTP Configuration
smtp_from_address = "noreply@example.com"
smtp_from_name    = "My Application"
smtp_host         = "smtp.gmail.com"
smtp_port         = 587
smtp_user         = "your-smtp-user@gmail.com"
smtp_password     = "CHANGE_ME_SMTP_PASSWORD" # ⚠️ Valeur dans le state Terraform
